---
import NavigationLink from '@components/Navigation/NavigationLink.astro';
// Credit: https://www.cyishere.dev/blog/astro-active-nav-item
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.split("/")[1];
---
<details class="relative">
    <summary class="cursor-pointer p-2 font-medium">&nbsp;</summary>
    <nav class="absolute top-full w-full left-0 right-0 flex flex-col z-50 justify-center">
        <NavigationLink
                url="/"
                label="Home"
                icon="fa-solid fa-house-chimney"
                currentPath={currentPath}
                itemPath="" />
        <NavigationLink
                url="/about/"
                label="About"
                icon="fa-solid fa-circle-info"
                currentPath={currentPath}
                itemPath="about" />
        <NavigationLink
                url="/posts/1"
                label="Blog"
                icon="fa-solid fa-pen-to-square"
                currentPath={currentPath}
                itemPath="posts" />
        <NavigationLink
                url="/micros/"
                label="Micros"
                icon="fa-solid fa-mobile-screen-button"
                currentPath={currentPath}
                itemPath="micros" />
        <NavigationLink
                url="/reading/"
                label="Reading"
                icon="fa-solid fa-book-open-reader"
                currentPath={currentPath}
                itemPath="reading"/>
        <NavigationLink
                url="/code/"
                label="Code"
                icon="fa-solid fa-code"
                currentPath={currentPath}
                itemPath="code" />
        <NavigationLink
                url="/etc/"
                label="Etc."
                icon="fa-solid fa-sink"
                currentPath={currentPath}
                itemPath="etc"/>

        <pagefind-modal-trigger compact="true" hide-shortcut="true" class="pagefind-modal-trigger"></pagefind-modal-trigger>
        <pagefind-modal></pagefind-modal>
    </nav>
</details>

<style>
    nav {
        /* From https://css.glass */
        background: rgba(235 235 235, 0.66);
        border-radius: 16px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        backdrop-filter: blur(9.1px);
        -webkit-backdrop-filter: blur(9.1px);
        border: 1px solid rgba(255, 255, 255, 1);
    }
    details {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.3s ease-out;
    }

    details > summary::before {
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        content: "\f0c9"; /* down arrow */
        margin-right: 10px;
    }

    details[open] > summary::before {
        font-family: "Font Awesome 6 Free";
        font-weight: 900;
        content: "\f00d"; /* down arrow */
        margin-right: 10px;
    }

    details summary {
        list-style: none;
    }
</style>