---
const { url, label, icon } = Astro.props;
console.log(icon)
---
<a href={url} aria-label={label} class="block text-center">
    <span><i class={`icon ${icon}`}></i></span>
    <span>{label}</span>
</a>

<style>
    a {
        font-family: var(--ff-subheads);
        line-height: 1.5;
        font-size: var(--font-size-h6);
    }
</style>