---
import {runSqliteQuery, QUERIES} from "@utils/db-operations.ts";
import {intToOrdinal, authorMatchesTag, slugify} from "@utils/utils.ts";
const {uniqueTags} = Astro.props;
const authorResults = runSqliteQuery(QUERIES.BOOKS_BY_AUTHOR);
---
<table>
    <thead>
        <tr>
            <td>
                Author
            </td>
            <td>
                Books Read
            </td>
        </tr>
    </thead>
    <tbody>
    {
        authorResults.map(
            function(authorRow, i: number) {
                let style = i % 2 == 0 ? 'even' : 'odd';
                return (
                    <tr class={style}>
                        <td>{
                            authorMatchesTag(authorRow.author, uniqueTags)
                                ? <a href=`/tags/${slugify(authorRow.author)}/`>{authorRow.author}</a>
                                : authorRow.author
                        }</td>
                        <td>{authorRow.total_books}</td>
                    </tr>
                )
            }
        )
    }
    </tbody>
</table>
<br />
