---
import {runSqliteQuery, QUERIES} from "@utils/db-operations.ts";
import {intToOrdinal} from "@utils/utils.ts";
const centuryDate = runSqliteQuery(QUERIES.BOOKS_BY_CENTURY);

const formatYear = function(year: number): string {
    return year > 0 ?
        intToOrdinal(year)
        : intToOrdinal(year * -1) + " BC";
}
---
<table>
    <thead>
        <tr>
            <td>
                Century
            </td>
            <td>
                Books Read
            </td>
        </tr>
    </thead>
    <tbody>
    {
        centuryDate.map(
            function(centuryRow, i: number) {
                let style = i % 2 == 0 ? 'even' : 'odd';
                return (
                    <tr class={style}>
                        <td>{formatYear(centuryRow.century)}</td>
                        <td>{centuryRow.total_books}</td>
                    </tr>
                )
            }
        )
    }
    </tbody>
</table>

<style>
    thead {
        background-color: var(--medium-blue);
        color: var(--nearly-white);
    }
    tbody tr.odd {
        background-color: var(--not-quite-nearly-white);
    }
</style>

