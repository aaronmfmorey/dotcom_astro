---
import {runSqliteQuery, QUERIES} from '@utils/db-operations.ts';
import StatsOverviewIndividual from "@components/Stats/StatsOverviewIndividual.astro";
import StatsContainer from "@components/Stats/StatsContainer.astro";
const booksAndPagesSummaryData: any = runSqliteQuery(QUERIES.BOOKS_AND_PAGES_SUMMARY)[0];
---
<StatsContainer>
    <StatsOverviewIndividual
            title="Books"
            value={booksAndPagesSummaryData.total_books_read}
            backgroundColor="var(--medium-blue)" />
    <StatsOverviewIndividual
            title="Pages"
            value={booksAndPagesSummaryData.total_pages_read}
            backgroundColor="var(--darker-green)" />
</StatsContainer>
