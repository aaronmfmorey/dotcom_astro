---
const {title, value, backgroundColor, formatter} = Astro.props;
---
<div class="hflex-item reading-widget">
    <div class="title-field" style={`background-color: ${backgroundColor};`}>
        {title}
    </div>
    <div class="number-field">
        {
            formatter ?
                formatter(value)
                : new Intl.NumberFormat('en-US').format(value)
        }
    </div>
</div>
