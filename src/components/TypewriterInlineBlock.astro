---
const {text} = Astro.props;
const textLength = text.length;
---
<span class="typewriter">
    <code>{text} <span class="cursor">▉</span></code>
</span>

<style define:vars={{ textLength: textLength }}>
    /* Typing effect CREDIT: https://css-tricks.com/snippets/css/typewriter-effect/ */
    .typewriter {
        margin-right: 1em;
    }

    .typewriter code {
        overflow: hidden; /* Ensures the content is not revealed until the animation */
        border-right: .15em solid green; /* The typwriter cursor */
        white-space: nowrap; /* Keeps the content on a single line */
        margin: 0 auto; /* Gives that scrolling effect as the typing happens */
        letter-spacing: .15em; /* Adjust as needed */
        animation:  typing 2s steps(var(--textLength)), blink-caret .75s step-end infinite;
        display: inline-block;
        width: calc(var(--textLength) * 1.5ch);
        font-size: 1em;
        font-family: 'Google Sans Code', monospace;
        vertical-align: bottom;
    }

    span:has(code) {
        padding-top: 5px;
        padding-bottom: 5px;
        padding-left: 5px;
        border-radius: 5px;
        /*background-color: var(--darker-font-color);*/
        color: #6af549;
        background-color: black;
        font-family: monospace;
        font-size: .8em;
    }

    span > code::before {
        content: "> ";
        font-weight: 800;
        /*animate: blinker 1s infinite;*/
    }

    @keyframes typing {
        from { width: 0 }
        to { width: calc(var(--textLength) * 1.5ch) }
    }

    /* The typewriter cursor effect */
    @keyframes blink-caret {
        from, to { border-color: transparent }
        50% { border-color: green; }
    }
</style>