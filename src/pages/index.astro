---
import type {ImageMetadata} from "astro";
import BaseLayout from '@layouts/BaseLayout.astro';
import BitmojiImage from "@components/BitmojiImage.astro";
import bookAndLaptop from '../assets/images/BookAndLaptopBitmoji.png';
import AboutText from "@contentsubmodule/data/about-me.html";
import AboutLinks from "@components/AboutLinks.astro";
import TypewriterInlineBlock from '@components/TypewriterInlineBlock.astro';
const pageTitle = "Aaron Morey";
const typewrittenText = `# I Am:
&nbsp;- A web developer in the Milwaukee area
&nbsp;- Working as a software development manager
 # I Have:
 &nbsp;- Over _fifteen years' experience_ across industries, including:
&nbsp;&nbsp;&nbsp;- Insurance, Finance, Marketing, and Warehousing/Logistics
 # I Believe In The Big C's:
 &nbsp;- Code, Customer service, Communication, and the Oxford [C]omma
 <Esc>:wq`;
---
<BaseLayout pageTitle={pageTitle}>
	<div class="flex w-full justify-center">
		<BitmojiImage src={bookAndLaptop} alt="A caricature of me reading a book in front of a laptop" />
	</div>
	<!--<AboutText/>-->
	<p>
		<TypewriterInlineBlock text={typewrittenText} client:visible />
	</p>
	<AboutLinks/>
</BaseLayout>
<style>
	span.experience {
		font-size: 0.9rem;
		font-family: monospace;
		font-style: italic;
		padding: 7px;
		padding-bottom: 0px;
		/*border: 1px var(--lighter-highlight) solid;*/
		border-bottom: 3px var(--lighter-highlight) solid;
		border-radius: 3px;
	}

	span.experience:hover {
		//font-size: 1rem;
		font-weight: bold;
		font-style: italic;
		border-radius: 3px;
	}

	.cursor {
		animation: blink 1.25s infinite;
		animation-fill-mode: both;
	}

	@keyframes blink {
		0% { opacity: 0 }
		50% { opacity: 1 }
		100% { opacity: 0 }
	}
</style>